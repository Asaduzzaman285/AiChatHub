APP_NAME="AI ChatHub Chat Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8006

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ai_chathub_db
DB_USERNAME=chat_app
DB_PASSWORD=chat_secret
DB_SCHEMA=chat_svc

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
BROADCAST_DRIVER=redis

INTERNAL_SERVICE_KEY=internal-secret-change-in-production

# S3-compatible storage (MinIO for local)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=aichathub-files
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

MAX_FILE_SIZE_MB=20
