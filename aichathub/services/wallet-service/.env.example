APP_NAME="AI ChatHub Wallet Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8003

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ai_chathub_db
DB_USERNAME=wallet_app
DB_PASSWORD=wallet_secret
DB_SCHEMA=wallet_svc

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
BROADCAST_DRIVER=redis

INTERNAL_SERVICE_KEY=internal-secret-change-in-production
NOTIFICATION_SERVICE_URL=http://notification-nginx

# Credit buffer default (USD) — overridden by system_config table
CREDIT_BUFFER_DEFAULT=3.00
LOW_BALANCE_THRESHOLD=5.00
