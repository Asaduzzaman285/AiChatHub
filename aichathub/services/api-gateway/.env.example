APP_NAME="AI ChatHub API Gateway"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# JWT secret must match auth-service
JWT_SECRET=CHANGE_ME_32_CHAR_MIN_SECRET_KEY

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=redis

# Downstream service URLs (Docker internal hostnames)
AUTH_SERVICE_URL=http://auth-nginx
SUBSCRIPTION_SERVICE_URL=http://subscription-nginx
WALLET_SERVICE_URL=http://wallet-nginx
PAYMENT_SERVICE_URL=http://payment-nginx
AI_GATEWAY_SERVICE_URL=http://ai-gateway-nginx
CHAT_SERVICE_URL=http://chat-nginx
BILLING_SERVICE_URL=http://billing-nginx

# Rate limiting (requests per minute per user)
RATE_LIMIT_PER_MINUTE=100

# The frontend's own origin — sole allowed CORS origin (config/cors.php). Point this at
# the real production domain when going live.
FRONTEND_URL=http://localhost:3000
