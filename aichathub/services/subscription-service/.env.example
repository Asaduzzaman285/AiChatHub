APP_NAME="AI ChatHub Subscription Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8002

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ai_chathub_db
DB_USERNAME=sub_app
DB_PASSWORD=sub_secret
DB_SCHEMA=subscription_svc

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis
# Every service with a dedicated queue worker needs a distinct value here — see the
# comment in the real .env for why (queue-name collision across services).
REDIS_QUEUE=subscription
CACHE_DRIVER=redis
BROADCAST_DRIVER=redis

# Internal service communication
INTERNAL_SERVICE_KEY=internal-secret-change-in-production
WALLET_SERVICE_URL=http://wallet-nginx
PAYMENT_SERVICE_URL=http://payment-nginx
BILLING_SERVICE_URL=http://billing-nginx
NOTIFICATION_SERVICE_URL=http://notification-nginx
AUTH_SERVICE_URL=http://auth-nginx
