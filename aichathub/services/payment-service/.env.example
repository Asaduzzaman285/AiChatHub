APP_NAME="AI ChatHub Payment Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8004

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ai_chathub_db
DB_USERNAME=payment_app
DB_PASSWORD=payment_secret
DB_SCHEMA=payment_svc

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis
# Distinct per-service queue name — without this, every service's queue worker polls
# the same literal Redis list and can silently steal/lose another service's jobs.
REDIS_QUEUE=payment
CACHE_DRIVER=redis
BROADCAST_DRIVER=redis

INTERNAL_SERVICE_KEY=internal-secret-change-in-production
WALLET_SERVICE_URL=http://wallet-nginx
BILLING_SERVICE_URL=http://billing-nginx
NOTIFICATION_SERVICE_URL=http://notification-nginx
SUBSCRIPTION_SERVICE_URL=http://subscription-nginx

# Base URL Stripe Checkout redirects back to after payment — the frontend's own origin
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME

# bKash (Phase 1 BD gateway) — theihasan/laravel-bkash package.
# These are bKash's own publicly-published sandbox demo merchant credentials
# (same values shown in the package's README / bKash's developer docs) — not
# account-specific like Stripe test keys, so no separate signup is needed to
# exercise the real sandbox API.
BKASH_SANDBOX=true
BKASH_APP_KEY=0vWQuCRGiUX7EPVjQDr0EUAYtc
BKASH_APP_SECRET=jcUNPBgbcqEDedNKdvE4G1cAK7D3hCjmJccNPZZBq96QIxxwAMEx
BKASH_USERNAME=01770618567
BKASH_PASSWORD=D7DaC<*E*eG
SANDBOX_BASE_URL=https://tokenized.sandbox.bka.sh
LIVE_BASE_URL=https://tokenized.pay.bka.sh
# Fixed conversion since bKash only settles in BDT while wallet/package prices
# are USD — adequate for a sandbox simulation, update by hand as the real rate drifts.
BKASH_USD_TO_BDT_RATE=122

# SSLCommerz
SSLCZ_STORE_ID=CHANGE_ME
SSLCZ_STORE_PASS=CHANGE_ME
SSLCZ_IS_SANDBOX=true
