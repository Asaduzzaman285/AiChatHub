APP_NAME="AI ChatHub Billing Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8007

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ai_chathub_db
DB_USERNAME=billing_app
DB_PASSWORD=billing_secret
DB_SCHEMA=billing_svc

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
BROADCAST_DRIVER=redis

INTERNAL_SERVICE_KEY=internal-secret-change-in-production
NOTIFICATION_SERVICE_URL=http://notification-nginx

# Invoice storage
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=aichathub-invoices
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
