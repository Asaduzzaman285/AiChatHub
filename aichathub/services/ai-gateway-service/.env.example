APP_NAME="AI ChatHub AI Gateway Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8005

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ai_chathub_db
DB_USERNAME=ai_app
DB_PASSWORD=ai_secret
DB_SCHEMA=ai_svc

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis
# Every service with a dedicated queue worker needs a distinct value here — see the
# comment in the real .env for why (queue-name collision across services).
REDIS_QUEUE=ai_gateway
CACHE_DRIVER=redis
BROADCAST_DRIVER=redis

# Internal service communication
INTERNAL_SERVICE_KEY=internal-secret-change-in-production
WALLET_SERVICE_URL=http://wallet-nginx
SUBSCRIPTION_SERVICE_URL=http://subscription-nginx
CHAT_SERVICE_URL=http://chat-nginx

# AI Providers — Laravel AI SDK
OPENAI_API_KEY=sk-CHANGE_ME
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
GEMINI_API_KEY=CHANGE_ME
XAI_API_KEY=xai-CHANGE_ME
ELEVENLABS_API_KEY=CHANGE_ME

# Default provider
AI_DEFAULT_PROVIDER=openai

# Request limits
AI_REQUEST_TIMEOUT_SECONDS=60
AI_STREAM_TIMEOUT_SECONDS=120
