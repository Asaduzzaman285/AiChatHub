APP_NAME="AI ChatHub Notification Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8008

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ai_chathub_db
DB_USERNAME=notif_app
DB_PASSWORD=notif_secret
DB_SCHEMA=notification_svc

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
BROADCAST_DRIVER=redis

INTERNAL_SERVICE_KEY=internal-secret-change-in-production

# Mail (Mailpit for local dev → real SMTP in production)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@aichathub.com"
MAIL_FROM_NAME="AI ChatHub"
