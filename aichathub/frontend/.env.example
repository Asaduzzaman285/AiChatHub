# Internal (server-to-server) — used by Next.js rewrites
API_GATEWAY_URL=http://api-gateway-nginx

# Public — exposed to browser
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Auth Service Google OAuth redirect
# This is where the auth-service redirects back to after Google consent
NEXT_PUBLIC_GOOGLE_REDIRECT_HANDLER=/auth/callback
